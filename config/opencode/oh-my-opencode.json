{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "hashline_edit": true,
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      },
      "fallback_models": ["workers-ai/workers-ai/@cf/moonshotai/kimi-k2.5", "openai/gpt-5.4"],
      "compaction": {
        "model": "google/gemini-3-flash-preview"
      }
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": ["openai/gpt-5.4"]
    },
    "oracle": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": ["google/gemini-3.1-pro-preview", "anthropic/claude-opus-4-6"],
      "compaction": {
        "model": "google/gemini-3-flash-preview"
      }
    },
    "librarian": {
      "model": "google/gemini-3-flash-preview"
    },
    "explore": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": ["openai/gpt-5-nano"]
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.4",
      "variant": "medium",
      "fallback_models": ["google/gemini-3-flash-preview", "openai/gpt-5-nano"]
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      },
      "fallback_models": ["openai/gpt-5.4", "google/gemini-3.1-pro-preview"],
      "compaction": {
        "model": "google/gemini-3-flash-preview"
      }
    },
    "metis": {
      "model": "anthropic/claude-opus-4-6",
      "variant": "max",
      "thinking": {
        "type": "enabled",
        "budgetTokens": 32000
      },
      "fallback_models": ["openai/gpt-5.4", "google/gemini-3.1-pro-preview"],
      "compaction": {
        "model": "google/gemini-3-flash-preview"
      }
    },
    "momus": {
      "model": "openai/gpt-5.4",
      "variant": "xhigh",
      "fallback_models": ["anthropic/claude-opus-4-6", "google/gemini-3.1-pro-preview"]
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": ["openai/gpt-5.4"]
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": ["anthropic/claude-opus-4-6"]
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh",
      "fallback_models": ["google/gemini-3.1-pro-preview", "anthropic/claude-opus-4-6"]
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium",
      "fallback_models": ["anthropic/claude-opus-4-6", "google/gemini-3.1-pro-preview"]
    },
    "artistry": {
      "model": "google/gemini-3.1-pro-preview",
      "variant": "high",
      "fallback_models": ["anthropic/claude-opus-4-6", "openai/gpt-5.4"]
    },
    "quick": {
      "model": "anthropic/claude-haiku-4-5",
      "fallback_models": ["google/gemini-3-flash-preview", "openai/gpt-5-nano"]
    },
    "unspecified-low": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": ["openai/gpt-5.3-codex", "google/gemini-3-flash-preview"]
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "high",
      "fallback_models": ["anthropic/claude-opus-4-6", "workers-ai/workers-ai/@cf/moonshotai/kimi-k2.5"]
    },
    "writing": {
      "model": "google/gemini-3-flash-preview",
      "fallback_models": ["anthropic/claude-sonnet-4-6"]
    }
  },
  "runtime_fallback": {
    "enabled": true
  },
  "git_master": {
    "commit_footer": false,
    "include_co_authored_by": false
  },
  "disabled_hooks": [
    "startup-toast",
    "auto-update-checker",
    "todo-continuation-enforcer",
    "ralph-loop",
    "write-existing-file-guard",
    "no-sisyphus-gpt"
  ],
  "experimental": {
    "safe_hook_creation": true,
    "aggressive_truncation": true,
    "auto_resume": false,
    "dynamic_context_pruning": {
      "enabled": true,
      "notification": "minimal",
      "turn_protection": {
        "enabled": true,
        "turns": 3
      },
      "strategies": {
        "deduplication": {
          "enabled": true
        },
        "supersede_writes": {
          "enabled": true,
          "aggressive": false
        },
        "purge_errors": {
          "enabled": true,
          "turns": 5
        }
      }
    }
  },
  "_migrations": []
}
